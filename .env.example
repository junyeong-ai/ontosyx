# Ontosyx Environment Variables
# Copy to .env and fill in your values.
# These override values in ontosyx.toml.

# LLM
OX_LLM__API_KEY=sk-your-api-key-here
# OX_LLM__PROVIDER=anthropic
# OX_LLM__MODEL=claude-sonnet-4-6
# OX_LLM__BASE_URL=https://api.anthropic.com/v1

# Graph DB
# OX_GRAPH__BACKEND=neo4j
# OX_GRAPH__PASSWORD=neo4j

# PostgreSQL
# OX_POSTGRES__URL=postgres://ontosyx:ontosyx@localhost:5432/ontosyx

# Server
# OX_SERVER__PORT=3001
# CORS origins — REQUIRED for any non-local deployment.
# Empty = permissive CORS (dev only). Set explicitly for production.
# OX_SERVER__CORS_ORIGINS=["http://localhost:3000"]

# Authentication
# JWT secret for platform tokens (required for OIDC auth)
# OX_AUTH__JWT_SECRET=your-jwt-secret-here
# Google OIDC client ID
# OX_AUTH__GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Session duration in hours (default: 24)
# OX_AUTH__SESSION_HOURS=24

# API key — fallback auth for programmatic/CI access.
# OX_API_KEY=your-secret-api-key

# Embedding (ONNX)
# Required when [embedding] provider = "onnx" in ontosyx.toml
# ORT_LIB_LOCATION=/opt/homebrew/Cellar/onnxruntime/1.24.3_1/lib
# ORT_PREFER_DYNAMIC_LINK=1
# DYLD_LIBRARY_PATH=/opt/homebrew/Cellar/onnxruntime/1.24.3_1/lib  # macOS only

# Logging
# OX_LOGGING__LEVEL=debug
